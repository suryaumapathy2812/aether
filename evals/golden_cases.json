{
  "version": "1.1",
  "defaults": {
    "timezone": "Asia/Kolkata",
    "max_latency_ms": 12000
  },
  "cases": [
    {
      "id": "calendar_tomorrow_requires_current_time_and_bounded_events",
      "category": "calendar",
      "description": "Relative date query must use current_time and only include in-window events.",
      "input": {
        "user_message": "What's my calendar looking like for tomorrow"
      },
      "mock_tools": {
        "current_time": {
          "now_iso": "2026-03-16T10:30:00+05:30",
          "timezone": "Asia/Kolkata"
        },
        "upcoming_events": {
          "events": [
            {
              "id": "evt-1",
              "summary": "[Hold] ForeverLearning - Prabhu",
              "start": "2026-03-17T02:00:00+05:30",
              "end": "2026-03-17T04:00:00+05:30"
            },
            {
              "id": "evt-old",
              "summary": "[Hold] BBRs",
              "start": "2025-01-31T16:30:00+05:30",
              "end": "2025-01-31T17:30:00+05:30"
            }
          ]
        }
      },
      "expect": {
        "required_tool_sequence": ["current_time", "upcoming_events"],
        "required_tool_args": {
          "upcoming_events": {
            "time_window": {
              "start": "2026-03-17T00:00:00+05:30",
              "end": "2026-03-18T00:00:00+05:30"
            }
          }
        },
        "response_must_include_any": ["[Hold] ForeverLearning - Prabhu", "2:00 AM", "4:00 AM"],
        "response_must_not_include_any": ["January", "February", "March 2025", "[Hold] BBRs", "Could you please confirm the current date"]
      }
    },
    {
      "id": "calendar_tomorrow_no_events_clear_message",
      "category": "calendar",
      "description": "If no events in tomorrow window, return clear empty response.",
      "input": {
        "user_message": "What's on my calendar tomorrow?"
      },
      "mock_tools": {
        "current_time": { "now_iso": "2026-03-16T21:00:00+05:30", "timezone": "Asia/Kolkata" },
        "upcoming_events": { "events": [] }
      },
      "expect": {
        "required_tool_sequence": ["current_time", "upcoming_events"],
        "response_must_include_any": ["Your calendar is clear for tomorrow"],
        "response_must_not_include_any": ["confirm the current date"]
      }
    },
    {
      "id": "gmail_unread_count_uses_count_tool",
      "category": "gmail",
      "description": "Unread count query should use exact count endpoint.",
      "input": {
        "user_message": "How many unread emails do I have?"
      },
      "mock_tools": {
        "inbox_count": { "messagesUnread": 12 }
      },
      "expect": {
        "required_tool_sequence": ["inbox_count"],
        "response_must_include_any": ["12 unread"],
        "response_must_not_include_any": ["resultSizeEstimate"]
      }
    },
    {
      "id": "drive_search_natural_language_normalizes_query",
      "category": "drive",
      "description": "Natural language Drive search must be normalized to valid API query syntax.",
      "input": {
        "user_message": "Can you find the document called project ai job finder in my Drive?"
      },
      "mock_tools": {
        "search_drive": { "files": [{ "id": "f1", "name": "project ai job finder" }] }
      },
      "expect": {
        "required_tool_sequence": ["search_drive"],
        "response_must_include_any": ["project ai job finder"],
        "response_must_not_include_any": ["Invalid Value", "400"]
      }
    },
    {
      "id": "tool_failure_recovery_corrects_on_retry",
      "category": "tool-recovery",
      "description": "After a recoverable tool failure the system should attempt a corrected tool call before stopping.",
      "input": {
        "user_message": "Search my drive for meeting notes"
      },
      "mock_tools": {
        "search_drive_attempt_1": { "error": true, "output": "Invalid Value" },
        "search_drive_attempt_2": { "files": [{ "id": "f2", "name": "meeting notes Q1" }] }
      },
      "expect": {
        "min_tool_calls": 2,
        "response_must_include_any": ["meeting notes"],
        "response_must_not_include_any": ["I could not", "I was unable", "sorry"]
      }
    },
    {
      "id": "permission_denied_no_forced_retry",
      "category": "tool-recovery",
      "description": "Permission denied errors must not be force-retried.",
      "input": {
        "user_message": "Delete all my emails"
      },
      "mock_tools": {
        "delete_emails": { "error": true, "output": "permission denied" }
      },
      "expect": {
        "max_tool_calls": 1,
        "response_must_not_include_any": ["deleted all"]
      }
    },
    {
      "id": "retry_policy_zero_means_no_retries",
      "category": "tool-recovery",
      "description": "When tool_retry_attempts is 0, no internal retries occur for transient failures.",
      "input": {
        "user_message": "Check the weather",
        "policy": { "tool_retry_attempts": 0 }
      },
      "mock_tools": {
        "get_weather": { "error": true, "output": "timeout while calling upstream" }
      },
      "expect": {
        "max_tool_calls": 1
      }
    },
    {
      "id": "multi_tool_chain_calendar_world_time",
      "category": "calendar",
      "description": "Calendar query requiring world_time first then upcoming_events in sequence.",
      "input": {
        "user_message": "What do I have scheduled today?"
      },
      "mock_tools": {
        "world_time": { "now_iso": "2026-03-16T14:00:00+05:30", "timezone": "Asia/Kolkata" },
        "upcoming_events": {
          "events": [
            { "id": "evt-standup", "summary": "Daily Standup", "start": "2026-03-16T10:00:00+05:30", "end": "2026-03-16T10:30:00+05:30" }
          ]
        }
      },
      "expect": {
        "required_tool_sequence": ["world_time", "upcoming_events"],
        "response_must_include_any": ["Daily Standup"],
        "response_must_not_include_any": ["confirm the current date"]
      }
    },
    {
      "id": "session_continuity_messages_persist",
      "category": "session",
      "description": "After sending a message and reloading, messages must persist and be loadable.",
      "input": {
        "user_message": "Remember that my favorite color is blue"
      },
      "expect": {
        "response_must_include_any": ["blue", "noted", "remember"],
        "session_reload_must_contain": ["favorite color"]
      }
    },
    {
      "id": "relative_date_no_events_clear_response",
      "category": "calendar",
      "description": "Relative date with no events should return a clear calendar-is-empty message.",
      "input": {
        "user_message": "Am I free this weekend?"
      },
      "mock_tools": {
        "world_time": { "now_iso": "2026-03-16T09:00:00+05:30", "timezone": "Asia/Kolkata" },
        "upcoming_events": { "events": [] }
      },
      "expect": {
        "required_tool_sequence": ["world_time", "upcoming_events"],
        "response_must_include_any": ["free", "clear", "no events"],
        "response_must_not_include_any": ["confirm the current date", "what day"]
      }
    }
  ]
}
