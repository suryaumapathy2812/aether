aether.suryaumapathy.in {
    # Auth routes go to dashboard (Nitro server functions)
    handle /api/auth* {
        reverse_proxy localhost:3000
    }

    # Skills content API goes to dashboard (Nitro server functions)
    handle /api/skills/* {
        reverse_proxy localhost:3000
    }

    # WebSocket routes go straight to the orchestrator
    handle /agent/v1/ws/* {
        reverse_proxy localhost:4000 {
            flush_interval -1
        }
    }

    # HTTP API routes go straight to orchestrator (direct routing, no Next.js proxy)
    handle /go/v1/* {
        reverse_proxy localhost:4000 {
            flush_interval -1
        }
    }

    handle /agent/v1/* {
        reverse_proxy localhost:4000 {
            flush_interval -1
        }
    }

    handle /api/go/* {
        reverse_proxy localhost:4000 {
            flush_interval -1
        }
    }

    # All other API routes go to the orchestrator
    handle /api/* {
        reverse_proxy localhost:4000 {
            flush_interval -1
        }
    }

    # Everything else to dashboard (TanStack Start SPA)
    handle {
        reverse_proxy localhost:3000
    }
}

*.aether.suryaumapathy.in {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }
    respond "Agent not found" 404
}

# Public MinIO S3 API endpoint (used by presigned upload/download URLs)
s3.aether.suryaumapathy.in {
    reverse_proxy localhost:9000 {
        # Preserve the original Host for AWS SigV4 presigned URLs
        header_up Host {http.request.host}
        header_up X-Forwarded-Host {http.request.host}
        header_up X-Forwarded-Proto {http.request.scheme}
    }
}

# MinIO Console
minio.aether.suryaumapathy.in {
    reverse_proxy localhost:9001
}

# Dozzle - container log viewer
dozzle.aether.suryaumapathy.in {
    reverse_proxy localhost:8080
}
