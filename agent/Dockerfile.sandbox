FROM debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    jq \
    python3 \
    python3-pip \
    nodejs \
    npm \
    git \
    wget \
    unzip \
    zip \
    bash \
    coreutils \
    && rm -rf /var/lib/apt/lists/*

# Common Python packages
RUN pip3 install requests beautifulsoup4 pandas --break-system-packages

# Common Node packages
RUN npm install -g axios

# Create workspace directory
RUN mkdir -p /workspace/documents \
    /workspace/downloads \
    /workspace/scripts \
    /workspace/data \
    /workspace/temp

WORKDIR /workspace

CMD ["tail", "-f", "/dev/null"]
