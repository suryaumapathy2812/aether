# Docker Compose env file (used with --env-file docker/.env)
# Copy this file to docker/.env and fill secrets.

DOMAIN=localhost
POSTGRES_PASSWORD=aether_dev

# Required runtime secrets
AGENT_SECRET=replace_me
BETTER_AUTH_SECRET=replace_me

# Dashboard trusted origins (comma-separated)
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3080

# Agent provisioning
AGENT_IMAGE=suryaumapathy2812/aether-agent:latest
AGENT_IDLE_TIMEOUT=1800
AGENT_HEALTH_TIMEOUT=30
AGENT_PORT=8000

# Default LLM credentials forwarded to provisioned agents
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Orchestrator routing behavior
AETHER_AUTO_ASSIGN_FIRST_AGENT=true
AETHER_DEFAULT_AGENT_ID=

# Browser-facing orchestrator URL (via Caddy proxy on :3080)
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:3080
NEXT_PUBLIC_ORCHESTRATOR_WS_URL=ws://localhost:3080
