# Docker Compose env file (used with --env-file docker/.env)
# Copy this file to docker/.env and fill secrets.

DOMAIN=localhost
POSTGRES_PASSWORD=aether_dev

# Required runtime secrets
AGENT_SECRET=replace_me
BETTER_AUTH_SECRET=replace_me

# Dashboard trusted origins (comma-separated)
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3080

# Agent provisioning
AGENT_IMAGE=suryaumapathy2812/aether-agent:latest
AGENT_NETWORK=
AGENT_IDLE_TIMEOUT=1800
AGENT_HEALTH_TIMEOUT=30
AGENT_PORT=8000

# Default LLM credentials forwarded to provisioned agents
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
AGENT_STATE_KEY=

# Web push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# MinIO / S3 settings forwarded into provisioned agents
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=
S3_BUCKET_TEMPLATE=core-ai-media-{user}
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true
S3_PUT_URL_TTL_SECONDS=300
S3_GET_URL_TTL_SECONDS=900

# Agent self-update source (GitHub releases)
AGENT_UPDATE_REPO=suryaumapathy2812/aether
AGENT_UPDATE_TOKEN=

# Orchestrator routing behavior
AETHER_AUTO_ASSIGN_FIRST_AGENT=true
AETHER_DEFAULT_AGENT_ID=
