# Aether Environment Configuration
#
# Copy to .env and fill in the REQUIRED values below.
# Everything else has working defaults.
#
#   cp docker/.env.example docker/.env
#
# Or run the interactive setup script which generates this for you:
#   ./docker/setup.sh

# =============================================================================
# REQUIRED — you must fill these in
# =============================================================================

# Your domain (DNS must point to this server)
DOMAIN=

# Secrets — generate with: openssl rand -base64 32
# setup.sh auto-generates these if left empty.
POSTGRES_PASSWORD=
BETTER_AUTH_SECRET=
AGENT_SECRET=

# LLM provider credentials (forwarded to agent containers)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# =============================================================================
# DEFAULTS — these work out of the box, override if needed
# =============================================================================

# --- Database (Postgres runs in Docker, exposed on host port 5432) ---
POSTGRES_DB=aether
POSTGRES_USER=aether
# DATABASE_URL is derived from POSTGRES_PASSWORD by setup.sh:
#   postgresql://aether:<POSTGRES_PASSWORD>@localhost:5432/aether
# Set explicitly here if your Postgres is elsewhere.
DATABASE_URL=

# --- Auth ---
# These are derived from DOMAIN by setup.sh. Set explicitly to override.
BETTER_AUTH_URL=
BETTER_AUTH_TRUSTED_ORIGINS=

# --- Agent container provisioning ---
AGENT_IMAGE=suryaumapathy2812/aether-agent:latest
AGENT_NETWORK=aether_internal
AGENT_IDLE_TIMEOUT=1800
AGENT_HEALTH_TIMEOUT=30
AGENT_PORT=8000
AGENT_ASSETS_ROOT=/var/lib/aether/agents

# --- S3 / MinIO (MinIO runs in Docker on aether_internal network) ---
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://aether-minio:9000
S3_BUCKET=
S3_BUCKET_TEMPLATE=core-ai-media-{user}
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true
S3_PUT_URL_TTL_SECONDS=300
S3_GET_URL_TTL_SECONDS=900

# --- Agent self-update (OTA via GitHub releases) ---
AGENT_UPDATE_REPO=suryaumapathy2812/aether
AGENT_UPDATE_TOKEN=

# --- Orchestrator routing ---
AETHER_AUTO_ASSIGN_FIRST_AGENT=true
AETHER_DEFAULT_AGENT_ID=

# --- Encryption key for sensitive data in agent SQLite (optional) ---
AGENT_STATE_KEY=

# --- Dozzle log viewer ---
DOZZLE_PORT=8080

# =============================================================================
# OPTIONAL — leave empty to disable
# =============================================================================

# Web push (VAPID keys for browser push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# OAuth providers (forwarded to agent containers for plugin auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Docker Hub (setup.sh uses this for docker login to avoid rate limits)
DOCKERHUB_USERNAME=
