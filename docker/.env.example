# Docker Compose env file (used with --env-file docker/.env)
# Copy this file to docker/.env and fill secrets.

DOMAIN=localhost
POSTGRES_PASSWORD=aether_dev

# Required runtime secrets
AGENT_SECRET=replace_me
BETTER_AUTH_SECRET=replace_me

# System fallback provider keys (optional but recommended)
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
SARVAM_API_KEY=

# Realtime P-worker defaults forwarded to spawned agents
AETHER_VOICE_BACKEND=gemini
AETHER_GEMINI_REALTIME_MODEL=gemini-2.5-flash-native-audio-latest
AETHER_GEMINI_TEXT_MODEL=gemini-2.5-flash
AETHER_GEMINI_VOICE=Puck
AETHER_GEMINI_LANGUAGE=en

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Shared model cache
AGENT_SHARED_MODELS_HOST_PATH=../.cache/models
AGENT_SHARED_MODELS_CONTAINER_PATH=/models

# Orchestrator-go routing behavior
AETHER_AUTO_ASSIGN_FIRST_AGENT=true
AETHER_DEFAULT_AGENT_ID=

# Browser websocket URL (dashboard notifications)
NEXT_PUBLIC_ORCHESTRATOR_WS_URL=ws://localhost:3080
