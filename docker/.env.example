# Aether Environment Configuration
#
# Copy to .env and fill in values:
#   cp docker/.env.example docker/.env
#
# Used by:
#   - docker-compose.services.yml  (Postgres, MinIO, Dozzle)
#   - ecosystem.config.js          (PM2: Dashboard + Orchestrator)
#   - setup.sh                     (interactive setup, generates this file)
#   - Caddyfile                    (reverse proxy, domain is hardcoded)

# =============================================================================
# DOMAIN
# =============================================================================

DOMAIN=aether.example.com

# =============================================================================
# DATABASE  (Postgres — runs in Docker via docker-compose.services.yml)
# =============================================================================

POSTGRES_PASSWORD=change-me
POSTGRES_DB=aether
POSTGRES_USER=aether

# Connection string used by Dashboard and Orchestrator (running on host via PM2).
# Points to localhost because Postgres exposes port 5432 to the host.
DATABASE_URL=postgresql://aether:change-me@localhost:5432/aether

# =============================================================================
# AUTH  (Dashboard — Better Auth)
# =============================================================================

# Secret key for signing auth tokens. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me

# Public URL of the dashboard (used for auth callbacks)
BETTER_AUTH_URL=https://aether.example.com

# Comma-separated origins allowed for auth requests
BETTER_AUTH_TRUSTED_ORIGINS=https://aether.example.com

# =============================================================================
# AGENT  (Orchestrator — agent container provisioning)
# =============================================================================

# Shared secret between orchestrator and agent containers
AGENT_SECRET=change-me

# Docker image for agent containers (pulled from Docker Hub)
AGENT_IMAGE=suryaumapathy2812/aether-agent:latest

# Docker network that agent containers join (must match docker-compose.services.yml)
AGENT_NETWORK=aether_internal

# Seconds before an idle agent container is stopped
AGENT_IDLE_TIMEOUT=1800

# Seconds to wait for agent health check on startup
AGENT_HEALTH_TIMEOUT=30

# Port the agent listens on inside its container
AGENT_PORT=8000

# Host path where per-user agent data is stored (state.db, workspace, skills)
AGENT_ASSETS_ROOT=/var/lib/aether/agents

# =============================================================================
# LLM  (forwarded to agent containers)
# =============================================================================

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Optional: encryption key for sensitive data in agent SQLite
AGENT_STATE_KEY=

# =============================================================================
# S3 / MINIO  (MinIO runs in Docker via docker-compose.services.yml)
# =============================================================================

# MinIO root credentials (used by docker-compose.services.yml)
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me

# S3 endpoint as seen from agent containers (on the aether_internal network)
S3_ENDPOINT=http://aether-minio:9000

# Bucket settings (forwarded to agent containers)
S3_BUCKET=
S3_BUCKET_TEMPLATE=core-ai-media-{user}
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true
S3_PUT_URL_TTL_SECONDS=300
S3_GET_URL_TTL_SECONDS=900

# =============================================================================
# WEB PUSH  (optional — VAPID keys for browser push notifications)
# =============================================================================

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# =============================================================================
# AGENT SELF-UPDATE  (OTA updates via GitHub releases)
# =============================================================================

AGENT_UPDATE_REPO=suryaumapathy2812/aether
AGENT_UPDATE_TOKEN=

# =============================================================================
# ORCHESTRATOR ROUTING
# =============================================================================

AETHER_AUTO_ASSIGN_FIRST_AGENT=true
AETHER_DEFAULT_AGENT_ID=

# =============================================================================
# OAUTH PROVIDERS  (optional — forwarded to agent containers for plugin auth)
# =============================================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# =============================================================================
# DOZZLE  (log viewer — runs in Docker via docker-compose.services.yml)
# =============================================================================

DOZZLE_PORT=8080
