aether.suryaumapathy.in {
    # Next.js auth routes must go to the dashboard
    handle /api/auth* {
        reverse_proxy localhost:3000
    }

    # All other API routes go to the orchestrator
    handle /api/* {
        reverse_proxy localhost:4000
    }

    # Everything else to dashboard
    handle {
        reverse_proxy localhost:3000
    }
}
