# Aether Caddy Configuration
#
# Usage:
#   docker run -d --name caddy -p 80:80 -p 443:443 \
#     -v $(pwd)/Caddyfile:/etc/caddy/Caddyfile \
#     -v caddy_data:/data \
#     caddy:latest

aether.suryaumapathy.in {
    # Handle API routes
    @api {
        path /api/*
    }

    # Dashboard is everything that's not API
    @dashboard {
        not @api
    }

    # Dashboard (Next.js)
    reverse_proxy @dashboard localhost:3000 {
        header_up X-Forwarded-Proto "https"
        header_up X-Forwarded-Host {host}
    }

    # API to Orchestrator
    reverse_proxy @api localhost:4000

    # Disable buffering for SSE/WebSocket
    flush_interval -1
}
