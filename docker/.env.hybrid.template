# Aether Environment Template
#
# Copy this to /opt/aether/.env and configure:
#   cp docker/.env.hybrid.template /opt/aether/.env
#
# This is for the hybrid setup:
#   - Dashboard & Orchestrator: Run directly (PM2)
#   - Postgres, MinIO, Dozzle: Docker containers
#   - Agents: Docker containers (spawned by orchestrator)

# === DOMAIN ===
DOMAIN=aether.suryaumapathy.in

# === DATABASE ===
POSTGRES_PASSWORD=change-me-secure-password
DATABASE_URL=postgresql://aether:${POSTGRES_PASSWORD}@localhost:5432/aether

# === AUTH ===
BETTER_AUTH_SECRET=change-me-secure-auth-secret
BETTER_AUTH_URL=https://aether.suryaumapathy.in
BETTER_AUTH_TRUSTED_ORIGINS=https://aether.suryaumapathy.in

# === AGENT ===
AGENT_SECRET=change-me-secure-agent-secret
AGENT_NETWORK=aether_internal

# === LLM ===
OPENAI_API_KEY=
OPENAI_BASE_URL=

# === S3/MinIO ===
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me-minio-password
S3_ENDPOINT=http://aether-minio:9000

# === OAUTH (Optional) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# === Dozzle ===
DOZZLE_PORT=8080
